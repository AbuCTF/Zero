APP_NAME=ZeroPool
APP_ENV=development
DEBUG=true
SECRET_KEY=your-super-secret-key-change-this-in-production

# Public URL where the app is accessible
APP_URL=http://localhost:3000
API_URL=http://localhost:8000

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://zeropool:zeropool@db:5432/zeropool

# For local development without Docker:
# DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/zeropool

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
REDIS_URL=redis://redis:6379/0

# For local development without Docker:
# REDIS_URL=redis://localhost:6379/0

# -----------------------------------------------------------------------------
# Security
# -----------------------------------------------------------------------------
# Session settings
SESSION_LIFETIME_HOURS=24
SESSION_COOKIE_NAME=zeropool_session
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_HTTPONLY=true
SESSION_COOKIE_SAMESITE=lax

# Password hashing (CTFd compatible)
PASSWORD_HASH_METHOD=pbkdf2:sha256
PASSWORD_HASH_ITERATIONS=600000

# Rate limiting
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=1000

# Account lockout
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION_MINUTES=15

# -----------------------------------------------------------------------------
# Cloudflare Turnstile (CAPTCHA)
# -----------------------------------------------------------------------------
# Get keys from: https://dash.cloudflare.com/turnstile
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# For development, use Cloudflare's test keys:
# TURNSTILE_SITE_KEY=1x00000000000000000000AA
# TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA

# -----------------------------------------------------------------------------
# Certificate Generation
# -----------------------------------------------------------------------------
# Salt for generating verification codes (change this!)
CERT_SALT=your-certificate-salt-change-this

# Font directory for certificate generation
FONTS_DIR=/app/fonts

# Generated certificates storage
CERTS_DIR=/app/storage/certificates

# -----------------------------------------------------------------------------
# File Storage
# -----------------------------------------------------------------------------
UPLOAD_DIR=/app/storage/uploads
MAX_UPLOAD_SIZE_MB=10

# -----------------------------------------------------------------------------
# Encryption
# -----------------------------------------------------------------------------
# Fernet key for encrypting sensitive data (provider credentials)
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# -----------------------------------------------------------------------------
# Email Defaults
# -----------------------------------------------------------------------------
# Default "From" name and email
EMAIL_FROM_NAME=ZeroPool
EMAIL_FROM_ADDRESS=noreply@h7tex.com

# -----------------------------------------------------------------------------
# CTFd Integration (Optional)
# -----------------------------------------------------------------------------
# Default CTFd instance URL (can be overridden per-event)
# CTFD_URL=https://ctf.yourdomain.com
# CTFD_API_KEY=your-ctfd-api-key

# -----------------------------------------------------------------------------
# Admin Bootstrap
# -----------------------------------------------------------------------------
# First admin account (created on first run)
ADMIN_EMAIL=
ADMIN_USERNAME=
ADMIN_PASSWORD=

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
LOG_LEVEL=INFO
LOG_FORMAT=json

CORS_ORIGINS=http://localhost:3000,http://localhost:5173

POSTGRES_USER=zeropool
POSTGRES_PASSWORD=zeropool
POSTGRES_DB=zeropool
