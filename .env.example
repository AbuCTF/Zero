# App
APP_NAME=ZeroPool
APP_ENV=development
DEBUG=true
SECRET_KEY=your-super-secret-key-change-this-in-production
APP_URL=http://localhost:3000
API_URL=http://localhost:8000

# Database
DATABASE_URL=postgresql+asyncpg://zeropool:zeropool@db:5432/zeropool
POSTGRES_USER=zeropool
POSTGRES_PASSWORD=zeropool
POSTGRES_DB=zeropool

# Redis
REDIS_URL=redis://redis:6379/0

# Security
SESSION_LIFETIME_HOURS=24
SESSION_COOKIE_NAME=zeropool_session
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_HTTPONLY=true
SESSION_COOKIE_SAMESITE=lax
PASSWORD_HASH_METHOD=pbkdf2:sha256
PASSWORD_HASH_ITERATIONS=600000
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=1000
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION_MINUTES=15

# Cloudflare Turnstile
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Certificates
CERT_SALT=your-certificate-salt-change-this
FONTS_DIR=/app/fonts
CERTS_DIR=/app/storage/certificates

# Storage
UPLOAD_DIR=/app/storage/uploads
MAX_UPLOAD_SIZE_MB=10

# Encryption (generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
ENCRYPTION_KEY=

# Email
EMAIL_FROM_NAME=ZeroPool
EMAIL_FROM_ADDRESS=noreply@example.com

# Admin (first run)
ADMIN_EMAIL=
ADMIN_USERNAME=
ADMIN_PASSWORD=

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
