:80 {
    # Request body size limit (50MB for file uploads)
    request_body {
        max_size 50MB
    }

    # API endpoints
    handle /api/* {
        reverse_proxy api:8000 {
            # Timeouts to prevent slowloris attacks
            transport http {
                read_timeout 30s
                write_timeout 30s
            }
        }
    }

    # Static file uploads
    handle /uploads/* {
        reverse_proxy api:8000 {
            transport http {
                read_timeout 60s
                write_timeout 60s
            }
        }
    }

    # Frontend
    handle {
        reverse_proxy web:3000 {
            transport http {
                read_timeout 30s
                write_timeout 30s
            }
        }
    }
}
